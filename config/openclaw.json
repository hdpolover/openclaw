{
  "gateway": {
    "mode": "local",
    "trustedProxies": ["loopback", "linklocal", "10.0.1.10"]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-3-pro-preview"
      }
    }
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "pairing",
      "selfChatMode": true
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "browserless",
    "profiles": {
      "browserless": {
        "cdpUrl": "ws://browser:3000"
      }
    }
  },
  "plugins": {
    "slots": {
      "memory": "memory-lancedb"
    },
    "entries": {
      "whatsapp": {
        "enabled": true
      },
      "memory-lancedb": {
        "enabled": true
      }
    }
  }
}
