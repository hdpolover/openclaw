{
  "gateway": {
    "mode": "local",
    "trustedProxies": ["loopback", "linklocal", "10.0.1.10"]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-3-pro-preview"
      }
    }
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "pairing"
    }
  },
  "plugins": {
    "entries": {
      "whatsapp": {
        "enabled": true
      }
    }
  }
}
